generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ActivityType {
  CREATED_BOARD
  UPDATED_BOARD
  DELETED_BOARD
  CREATED_COLUMN
  UPDATED_COLUMN
  DELETED_COLUMN
  CREATED_TASK
  UPDATED_TASK
  DELETED_TASK
  MOVED_TASK
}

enum BoardRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum BoardType {
  PUBLIC
  PRIVATE
}

model Board {
  id    String    @id @default(auto()) @map("_id") @db.ObjectId
  title String
  type  BoardType @default(PRIVATE)

  columns    Column[]
  activities Activity[]
  members    BoardMember[]

  User        User   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id     String       @id @default(auto()) @map("_id") @db.ObjectId
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  type   ActivityType

  message  String?
  metadata Json?

  board    Board?  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId  String? @db.ObjectId
  column   Column? @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId String? @db.ObjectId
  task     Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String? @db.ObjectId

  createdAt DateTime @default(now())
}

model BoardMember {
  id   String    @id @default(auto()) @map("_id") @db.ObjectId
  role BoardRole

  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String

  @@unique([boardId, userId])
}

model Column {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  position    Float
  isCollapsed Boolean @default(false)

  activities Activity[]
  tasks      Task[]

  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Task {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  title    String
  position Float

  description String?
  dueDate     DateTime?

  activities Activity[]

  column    Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId  String   @db.ObjectId
  members   User[]   @relation(fields: [memberIds], references: [id])
  memberIds String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([columnId])
}

model User {
  id            String  @id @map("_id")
  name          String
  email         String
  emailVerified Boolean @default(false)

  image String?

  sessions      Session[]
  accounts      Account[]
  activities    Activity[]
  boards        BoardMember[]
  createdBoards Board[]

  tasks   Task[]   @relation(fields: [taskIds], references: [id])
  taskIds String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @map("_id")
  expiresAt DateTime
  token     String

  ipAddress String?
  userAgent String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([token])
  @@map("session")
}

model Account {
  id         String @id @map("_id")
  accountId  String
  providerId String

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("verification")
}
